# === API LLM (Choisir UN) ===
# Groq (Gratuit) - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# === API Météo (Gratuit) ===
# https://openweathermap.org/api
OPENWEATHER_API_KEY=your-weather-api-key-here

# === Configuration ===
DEFAULT_CITY=Valenciennes
DEFAULT_CAMPUS=INSA Hauts-de-France
DEBUG_MODE=true
LOG_LEVEL=INFO

# === LLM Choice ===
LLM_PROVIDER=gemini
# Options: gemini, groq